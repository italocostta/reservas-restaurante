# Session pooler (porta 5432, host pooler.supabase.com) — não a direct connection
# (IPv6-only) nem a transaction pooler (6543, quebra prepared statements do pgx).
# sslmode=require é obrigatório.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require

PORT=8080
CORS_ALLOWED_ORIGIN=http://localhost:5173
ENV=development

# Horário de funcionamento do restaurante (seções 3 e 7 da spec)
SERVICE_START=18:00
SERVICE_END=23:00
SERVICE_TZ=America/Sao_Paulo
